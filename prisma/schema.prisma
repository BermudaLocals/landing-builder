generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  projects Project[]
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  title       String
  slug        String   @unique
  description String?
  components  Json     // Array of component data
  styles      Json?    // Global styles
  seo         Json?    // SEO settings
  published   Boolean  @default(false)
  publishedUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([slug])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  preview     String?  // Preview image URL
  components  Json     // Template components
  styles      Json?    // Template styles
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
}
